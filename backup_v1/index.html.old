<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#4caf50" />
    <title>Kas Warga</title>
    <link rel="icon" type="image/x-icon" href="icons/wordmark-favicon.ico" />
    <link rel="stylesheet" href="style.css" />
    <script defer type="module" src="./script.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lexend:wght@100..900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div id="PTTH">
      <img
        id="logoPTTH"
        src="./icons/kas-warga-high-resolution-logo-transparent.png"
        alt="Permata Tajur Town House"
      />
      <h1 id="textPTTH">Permata Tajur Town House</h1>
    </div>
    <div id="mainFlexContainer">
      <!-- <h1 class="PPTH">Permata Tajur Town House</h1> -->
      <div id="leftColumn">
        <div class="balanceContainer">
          <h1>Kas Warga</h1>
          <h2>Balance: <span id="balance">Rp 0</span></h2>
        </div>
        <div class="paymentContainer">
          <h1>Payment</h1>
          <div
            id="paymentTypeSelector"
            style="
              margin-bottom: 16px;
              display: flex;
              flex-wrap: wrap;
              gap: 6px;
              justify-content: center;
            "
          >
            <button id="btnIPL" class="paymentTypeBtn" data-type="IPL">
              IPL
            </button>
            <button id="btnTHR" class="paymentTypeBtn" data-type="THR">
              THR
            </button>
            <button
              id="btnIuranLain"
              class="paymentTypeBtn"
              data-type="IuranLain"
            >
              Iuran Lain
            </button>
          </div>
          <!-- </div> -->

          <!-- Section: IPL (Ruko & Rumah) -->
          <div id="sectionIPL" style="display: none">
            <!-- Step 1 Radio Option Iuran-->
            <div id="propertyStep">
              <label>
                <input type="radio" name="propertyType" value="Ruko" />
                Ruko
              </label>
              <label>
                <input type="radio" name="propertyType" value="Rumah" />
                Rumah
              </label>
            </div>
            <!-- Step 2 for Rumah -->
            <div
              id="blockRumah"
              style="display: none; margin-top: 10px; margin-bottom: 10px"
            >
              <label>
                <input type="radio" name="blockRumahType" value="A" />
                A
              </label>
              <label>
                <input type="radio" name="blockRumahType" value="B" />
                B
              </label>
            </div>
            <!-- Step 3 for Rumah A -->
            <div
              id="blockRumahTypeA"
              style="display: none; margin-top: 10px; margin-bottom: 10px"
            >
              <!-- Will be populated dynamically from Supabase units table -->
            </div>
            <!-- Step 3 for Rumah B -->
            <div
              id="blockRumahTypeB"
              style="display: none; margin-top: 10px; margin-bottom: 10px"
            >
              <!-- Will be populated dynamically from Supabase units table -->
            </div>
            <!-- Step 2 for Ruko -->
            <div
              id="blockRuko"
              style="display: none; margin-top: 10px; margin-bottom: 10px"
            >
              <!-- Will be populated dynamically from Supabase units table -->
            </div>
          </div>

          <!-- Section: THR -->
          <div id="sectionTHR" style="display: none">
            <div id="blockTHR" style="margin-top: 10px; margin-bottom: 10px">
              <!-- Will be populated dynamically with THR list -->
            </div>
          </div>

          <!-- Section: Iuran Tembok (Iuran Lain) -->
          <div id="sectionIuranTembok" style="display: none">
            <div
              id="blockIuranTembok"
              style="margin-top: 10px; margin-bottom: 10px"
            >
              <!-- Will be populated dynamically with Rumah units -->
            </div>
          </div>

          <div id="bayarTransaksi">
            <input
              type="number"
              id="iuranJumlahBulan"
              placeholder="Mau berapa bulan, Pak?"
              min="1"
              max="12"
            />
            <button id="iuranButton">Bayar</button>
          </div>
        </div>
      </div>
      <div id="rightColumn">
        <div class="correctionContainer">
          <h1>Correction</h1>

          <!-- Deposit Section -->
          <div id="depositSection" class="transaction-section">
            <img
              src="./icons/piggy-bank-saving.png"
              alt="Deposit"
              class="transaction-icon"
            />
            <h3
              style="
                margin-top: 0;
                margin-bottom: 12px;
                font-size: 14px;
                color: #28a745;
              "
            >
              Deposit
            </h3>
            <input type="text" id="depositAmount" placeholder="Enter amount" />
            <input
              type="text"
              id="depositDescription"
              placeholder="e.g., IPL Payment - R1 Nasir"
            />
            <button id="depositButton">Deposit</button>
          </div>

          <!-- Separator -->
          <div style="height: 1px; background: #e3f2e1; margin: 12px 0"></div>

          <!-- Withdraw Section -->
          <div id="withdrawSection" class="transaction-section">
            <img
              src="./icons/piggy-bank-dead-hammer.png"
              alt="Withdraw"
              class="transaction-icon"
            />
            <h3
              style="
                margin-top: 0;
                margin-bottom: 12px;
                font-size: 14px;
                color: #dc3545;
              "
            >
              Withdraw
            </h3>
            <input type="text" id="withdrawAmount" placeholder="Enter amount" />
            <select id="expenseCategory" required>
              <option value="">-- Select Category --</option>
            </select>
            <input
              type="text"
              id="withdrawDescription"
              placeholder="e.g., Gate repair"
            />
            <button id="withdrawButton">Withdraw</button>
          </div>
        </div>
        <div class="transactionsContainer">
          <h1>Transactions</h1>
          <ul id="transactionsHistory"></ul>
          <div
            id="transactionPaginationContainer"
            class="transaction-pagination"
          >
            <button
              id="paginationPrev"
              class="pagination-btn pagination-prev"
              style="display: none"
            >
              ← Newer
            </button>
            <span id="pageInfo" class="page-info">Page 1 of 1</span>
            <button
              id="paginationNext"
              class="pagination-btn pagination-next"
              style="display: none"
            >
              Older →
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Payment Tracker Section -->
    <div id="paymentTrackerContainer">
      <h1>Payment Tracker</h1>
      <table>
        <thead id="paymentTrackerBody"></thead>
      </table>
      <div id="paymentYearSelector">
        <label for="paymentYear">Year:</label>
        <select id="paymentYear">
          <option value="2025">2025</option>
          <option value="2026">2026</option>
          <option value="2027">2027</option>
        </select>
      </div>
      <div id="iuranTableTabs">
        <button id="tabRuko" class="active">Ruko</button>
        <button id="tabRumah">Rumah</button>
        <button id="tabTHR">THR</button>
      </div>
      <div id="iuranTableContent">
        <!-- Table will be rendered here by JS -->
      </div>
    </div>

    <script>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker
            .register("/service-worker.js")
            .then((reg) => console.log("Service Worker registered:", reg.scope))
            .catch((err) => console.log("Service Worker failed:", err));
        });
      }
    </script>
  </body>
</html>
